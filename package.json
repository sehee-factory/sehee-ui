{
  "scripts": {
    "prepare": "husky",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "check": "pnpm lint && pnpm format:check",
    "fix": "pnpm lint:fix && pnpm format",
    "dev": "pnpm dev:ui & pnpm dev:web",
    "dev:web": "pnpm --filter web dev",
    "dev:ui": "pnpm --filter @sehee/ui dev",
    "build": "pnpm -r build",
    "build:web": "pnpm --filter web build",
    "build:ui": "pnpm --filter @sehee/ui build"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.59.1",
    "@typescript-eslint/parser": "^8.59.1",
    "eslint": "^10.2.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.3"
  },
  "lint-staged": {
    "*.{js,ts,tsx,json,md}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.2.4",
    "tailwindcss": "^4.2.4"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ]
}
